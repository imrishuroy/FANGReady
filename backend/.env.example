# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=release
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_SHUTDOWN_TIMEOUT=30s

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# CockroachDB Configuration
DB_HOST=your-cluster.cockroachlabs.cloud
DB_PORT=26257
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=faangready
DB_SSL_MODE=verify-full
DB_SSL_ROOT_CERT=$HOME/.postgresql/root.crt

# Connection Pool
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=1m

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Authentication
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=168h
BCRYPT_COST=12

# Judge0 Code Execution
# For local Docker (Linux only): http://localhost:2358
# For RapidAPI: https://judge0-ce.p.rapidapi.com
# Set JUDGE0_MOCK_MODE=true for local development without Judge0
JUDGE0_URL=http://localhost:2358
JUDGE0_API_KEY=
JUDGE0_MOCK_MODE=false
JUDGE0_CPU_TIME_LIMIT=5.0
JUDGE0_WALL_TIME_LIMIT=10.0
JUDGE0_MEMORY_LIMIT=128000
JUDGE0_STACK_LIMIT=64000
JUDGE0_POLL_INTERVAL=500ms
JUDGE0_MAX_POLL_TIME=30s
